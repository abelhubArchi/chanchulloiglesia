<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="Biblia Reina Valera - Herramienta de estudio bíblico">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    
    <!-- CSS Vainilla -->
    <link rel="stylesheet" href="/css/index.css">
    
    <!-- FontAwesome (opcional para iconos rápidos, podemos cambiarlo a SVGs inline luego) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3b82f6">
</head>
<body class="<%= page %>-page">
    <%- include('partials/navbar') %>
    
    <!-- Offline Indicator -->
    <div id="offlineBadge" class="offline-badge hidden">
        <i class="fas fa-wifi-slash"></i> Modo Offline Activado - Biblia Disponible
    </div>

    <!-- PWA Install Banner -->
    <div id="installBanner" class="install-banner hidden">
        <div class="install-banner-content">
            <i class="fas fa-mobile-alt"></i>
            <div>
                <strong>Instalar App Nativa</strong>
                <p id="installMessage">Guarda esta app en tu inicio para acceder rápido y sin internet.</p>
            </div>
        </div>
        <div class="install-banner-actions">
            <button id="installBtn" class="btn btn-primary btn-small">Instalar</button>
            <button id="closeInstallBtn" class="btn-icon">&times;</button>
        </div>
    </div>
    
    <div class="app-container">
        <%- include('partials/sidebar-left') %>
        
        <main class="main-content">
            <%- body %>
        </main>
        
        <%- include('partials/sidebar-right') %>
    </div>

    <!-- Modal para Prompts -->
    <div id="promptModal" class="modal hidden">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Prompt Generado</h2>
                <button class="close-btn" id="closeModal">&times;</button>
            </div>
            <div class="modal-body">
                <textarea id="promptTextarea" readonly></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" id="copyPromptBtn">
                    <i class="fas fa-copy"></i> Copiar Prompt
                </button>
                <a href="https://chatgpt.com/" target="_blank" class="btn btn-outline" id="openChatGptBtn">
                    Abrir ChatGPT
                </a>
                <a href="https://gemini.google.com/" target="_blank" class="btn btn-outline" id="openGeminiBtn">
                    Abrir Gemini
                </a>
            </div>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
